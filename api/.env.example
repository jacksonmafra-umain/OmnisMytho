# Omnis Mytho API — Environment Variables

# For content generation (optional, seed data is included)
ANTHROPIC_API_KEY=sk-ant-...

# LLM enrichment — OpenAI primary, Gemini fallback (at least one required)
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# For image generation
FAL_KEY=...           # nano-banana backend (Fal.ai)
