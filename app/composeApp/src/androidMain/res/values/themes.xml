<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme -->
    <style name="Theme.OmnisMytho" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash screen theme (Android 12+) -->
    <style name="Theme.OmnisMytho.Splash" parent="Theme.OmnisMytho">
        <item name="android:windowSplashScreenBackground">#1A1410</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#1A1410</item>
    </style>
</resources>
